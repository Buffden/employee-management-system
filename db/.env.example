# Employee Management System - Environment Variables
# Copy this file to .env and update with your actual values
# cp .env.example .env

# ============================================
# Docker & Deployment Configuration
# ============================================
# Docker image tag (usually git SHA for production, or 'latest' for local)
IMAGE_TAG=latest

# ============================================
# Database Configuration
# ============================================
# PostgreSQL database connection settings
DB_HOST=postgres
DB_PORT=5432
DB_NAME=employee_management_system
DB_USER=ems_user
DB_PWD=change_me_secure_password
# Database SSL mode: 'disable' for local, 'require' for production
DB_SSL_MODE=disable

# ============================================
# Redis Configuration
# ============================================
# Redis connection settings (for rate limiting and caching)
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# Spring Boot Configuration
# ============================================
# Spring profile: 'dev' for local development, 'prod' for production
SPRING_PROFILE=dev

# ============================================
# Security Configuration
# ============================================
# JWT secret key for token signing (use a strong random string in production)
JWT_SECRET_KEY=change_me_jwt_secret_key_min_32_characters_long

# CORS allowed origins (comma-separated list)
# For local development: http://localhost:4200,http://localhost
# For production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost

# ============================================
# Frontend Configuration
# ============================================
# Base URL for the frontend application
# For local development: http://localhost
# For production: https://yourdomain.com
FRONTEND_BASE_URL=http://localhost

# ============================================
# Admin User Configuration
# ============================================
# Whether to create admin user on startup (true/false)
ADMIN_CREATE=false
# Admin user credentials (only used if ADMIN_CREATE=true)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password
ADMIN_EMAIL=admin@example.com

# ============================================
# Email Service Configuration
# ============================================
# Email service provider: 'demo', 'sendgrid', etc.
EMAIL_SERVICE_PROVIDER=demo
# SendGrid API key (required if EMAIL_SERVICE_PROVIDER=sendgrid)
EMAIL_SENDGRID_API_KEY=
# SendGrid sender email address
EMAIL_SENDGRID_FROM_EMAIL=noreply@example.com
# SendGrid sender name
EMAIL_SENDGRID_FROM_NAME=Employee Management System

# ============================================
# Production/EC2 Configuration
# ============================================
# EC2 host address (for production deployments)
EC2_HOST=
# Nginx port (usually 80 for HTTP, 443 for HTTPS)
NGINX_PORT=80
# Nginx server name (domain name)
NGINX_SERVER_NAME=localhost
# SSL enabled flag (true/false)
SSL_ENABLED=false
